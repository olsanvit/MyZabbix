@page "/admin"
@rendermode InteractiveServer

<PageTitle>Admin — MyZabbix</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h4 class="m-0"><i class="bi bi-shield-lock me-2 text-accent"></i>Admin — MyZabbix</h4>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else
{
    <!-- Statistiky -->
    <div class="row g-3 mb-3 ui-anim-fade-up">
        <div class="col-6 col-md-3">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold @(_isConnected ? "text-success" : "text-danger")">
                    @(_isConnected ? "Online" : "Offline")
                </div>
                <div class="text-muted small">Zabbix připojení</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-accent">@_hostCount</div>
                <div class="text-muted small">Hosts</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-danger">@_problemCount</div>
                <div class="text-muted small">Problémy</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="ui-panel text-center p-3">
                <div class="fs-3 fw-bold text-warning">@_triggerCount</div>
                <div class="text-muted small">Triggery</div>
            </div>
        </div>
    </div>

    <!-- Konfigurační přehled -->
    <div class="row g-3">
        <div class="col-md-6">
            <div class="ui-panel h-100 ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-gear text-accent"></i>Konfigurace Zabbix
                    </span>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <tbody>
                            <tr><th class="w-50">Server URL</th><td><code class="small">@_zabbixUrl</code></td></tr>
                            <tr><th>Stav</th><td><span class="badge @(_isConnected ? "bg-success" : "bg-danger")">@(_isConnected ? "Připojen" : "Odpojen")</span></td></tr>
                            <tr><th>Hosts</th><td>@_hostCount</td></tr>
                            <tr><th>Problémy</th><td>@_problemCount</td></tr>
                            <tr><th>Triggery</th><td>@_triggerCount</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="ui-panel h-100 ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-lightning text-accent"></i>Rychlé akce
                    </span>
                </div>
                <div class="p-3 d-flex flex-column gap-2">
                    <a href="/hosts" class="btn btn-outline-primary btn-sm"><i class="bi bi-broadcast me-1"></i>Přejít na Hosts</a>
                    <a href="/problems" class="btn btn-outline-danger btn-sm"><i class="bi bi-exclamation-triangle me-1"></i>Přejít na Problémy</a>
                    <a href="/triggers" class="btn btn-outline-warning btn-sm"><i class="bi bi-bell me-1"></i>Přejít na Triggery</a>
                    <a href="/settings" class="btn btn-outline-secondary btn-sm"><i class="bi bi-sliders me-1"></i>Nastavení</a>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="alert alert-warning mt-3 ui-anim-fade-up">@_errorMsg</div>
    }
}

@code {
    [Inject] private ZabbixApiService ZabbixApi { get; set; } = default!;
    [Inject] private IConfiguration Config { get; set; } = default!;

    private bool _loading = true;
    private bool _isConnected;
    private int _hostCount, _problemCount, _triggerCount;
    private string _zabbixUrl = string.Empty;
    private string _errorMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _zabbixUrl = Config["Zabbix:Url"] ?? "—";
        try
        {
            var hosts    = await ZabbixApi.GetHostsAsync();
            var problems = await ZabbixApi.GetProblemsAsync();
            var triggers = await ZabbixApi.GetTriggersAsync();
            _hostCount    = hosts?.Count    ?? 0;
            _problemCount = problems?.Count ?? 0;
            _triggerCount = triggers?.Count ?? 0;
            _isConnected  = true;
        }
        catch (Exception ex)
        {
            _isConnected = false;
            _errorMsg    = $"Nelze se připojit k Zabbix: {ex.Message}";
        }
        _loading = false;
    }
}
