@page "/admin"
@rendermode InteractiveServer

<PageTitle>Admin — MyZabbix</PageTitle>

<div class="dash-switcher mb-3">
    <h4 class="m-0">Admin — MyZabbix</h4>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else
{
    <!-- Statistiky -->
    <div class="row g-3 mb-3">
        <div class="col-6 col-md-3">
            <div class="card text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold @(_isConnected ? "text-success" : "text-danger")">
                        @(_isConnected ? "Online" : "Offline")
                    </div>
                    <div class="text-muted small">Zabbix připojení</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold text-primary">@_hostCount</div>
                    <div class="text-muted small">Hosts</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold text-danger">@_problemCount</div>
                    <div class="text-muted small">Problémy</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center">
                <div class="card-body py-2">
                    <div class="fs-4 fw-bold text-warning">@_triggerCount</div>
                    <div class="text-muted small">Triggery</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Konfigurační přehled -->
    <div class="row g-3">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Konfigurace Zabbix</div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr><th class="w-50">Server URL</th><td><code class="small">@_zabbixUrl</code></td></tr>
                            <tr><th>Stav</th><td><span class="badge @(_isConnected ? "bg-success" : "bg-danger")">@(_isConnected ? "Připojen" : "Odpojen")</span></td></tr>
                            <tr><th>Hosts</th><td>@_hostCount</td></tr>
                            <tr><th>Problémy</th><td>@_problemCount</td></tr>
                            <tr><th>Triggery</th><td>@_triggerCount</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header fw-bold">Rychlé akce</div>
                <div class="card-body d-flex flex-column gap-2">
                    <a href="/hosts" class="btn btn-outline-primary btn-sm">📡 Přejít na Hosts</a>
                    <a href="/problems" class="btn btn-outline-danger btn-sm">⚠️ Přejít na Problémy</a>
                    <a href="/triggers" class="btn btn-outline-warning btn-sm">🔔 Přejít na Triggery</a>
                    <a href="/settings" class="btn btn-outline-secondary btn-sm">⚙️ Nastavení</a>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="alert alert-warning mt-3">@_errorMsg</div>
    }
}

@code {
    [Inject] private ZabbixApiService ZabbixApi { get; set; } = default!;
    [Inject] private IConfiguration Config { get; set; } = default!;

    private bool _loading = true;
    private bool _isConnected;
    private int _hostCount, _problemCount, _triggerCount;
    private string _zabbixUrl = string.Empty;
    private string _errorMsg = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _zabbixUrl = Config["Zabbix:Url"] ?? "—";
        try
        {
            var hosts    = await ZabbixApi.GetHostsAsync();
            var problems = await ZabbixApi.GetProblemsAsync();
            var triggers = await ZabbixApi.GetTriggersAsync();
            _hostCount    = hosts?.Count    ?? 0;
            _problemCount = problems?.Count ?? 0;
            _triggerCount = triggers?.Count ?? 0;
            _isConnected  = true;
        }
        catch (Exception ex)
        {
            _isConnected = false;
            _errorMsg    = $"Nelze se připojit k Zabbix: {ex.Message}";
        }
        _loading = false;
    }
}
