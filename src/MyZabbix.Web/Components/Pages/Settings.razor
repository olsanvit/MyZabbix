@page "/settings"
@inject ILocalStorageService LocalStorage
@inject IConfiguration Config
@inject NavigationManager Nav

<PageTitle>Settings — MyZabbix</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-gear"></i> Settings</h3>
    @if (Zabbix.IsAuthenticated)
    {
        <span class="badge bg-success">
            <i class="bi bi-check-circle me-1"></i>Connected
        </span>
    }
</div>

<div class="row g-3 ui-anim-fade-up">
    <div class="col-lg-5">
        <div class="ui-panel">
            <div class="ui-panel-header">
                <span class="ui-panel-title">
                    <i class="bi bi-plug text-accent"></i>
                    Zabbix Connection
                </span>
            </div>
            <div class="p-3">
                <div class="d-flex flex-column gap-3">
                    <div>
                        <label class="form-label text-muted small mb-1">Zabbix Server URL</label>
                        <input class="form-control form-control-sm"
                               style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:var(--ui-text-1)"
                               placeholder="http://your-zabbix-server"
                               @bind="_url" />
                    </div>
                    <div>
                        <label class="form-label text-muted small mb-1">Username</label>
                        <input class="form-control form-control-sm"
                               style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:var(--ui-text-1)"
                               placeholder="Admin"
                               @bind="_username" />
                    </div>
                    <div>
                        <label class="form-label text-muted small mb-1">Password</label>
                        <input class="form-control form-control-sm"
                               style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:var(--ui-text-1)"
                               type="password"
                               @bind="_password" />
                    </div>

                    <div class="d-flex gap-2 align-items-center">
                        <button class="btn btn-primary btn-sm" @onclick="ConnectAsync" disabled="@_connecting">
                            @if (_connecting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            <i class="bi bi-plug me-1"></i>Connect
                        </button>
                        @if (Zabbix.IsAuthenticated)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="DisconnectAsync">
                                <i class="bi bi-plug-fill me-1"></i>Disconnect
                            </button>
                        }
                    </div>

                    @if (Zabbix.IsAuthenticated)
                    {
                        <div class="p-2 rounded" style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3)">
                            <div class="d-flex align-items-center gap-2 text-success small">
                                <i class="bi bi-check-circle-fill"></i>
                                <span>Connected to <strong>@Zabbix.ServerUrl</strong></span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _url = "";
    private string _username = "";
    private string _password = "";
    private bool _connecting;

    protected override async Task OnInitializedAsync()
    {
        _url      = await LocalStorage.GetItemAsStringAsync("zabbix_url")      ?? Config["Zabbix:Url"]      ?? "";
        _username = await LocalStorage.GetItemAsStringAsync("zabbix_username") ?? Config["Zabbix:Username"] ?? "Admin";
        _password = Config["Zabbix:Password"] ?? "";

        if (!string.IsNullOrWhiteSpace(_url) &&
            !string.IsNullOrWhiteSpace(_username) &&
            !string.IsNullOrWhiteSpace(_password) &&
            !Zabbix.IsAuthenticated)
        {
            await ConnectAsync();
        }
    }

    private async Task ConnectAsync()
    {
        if (string.IsNullOrWhiteSpace(_url) || string.IsNullOrWhiteSpace(_username))
        {
            Alerts.Warning("Please fill in URL and username.");
            return;
        }

        _connecting = true;
        try
        {
            var ok = await Zabbix.LoginAsync(_url, _username, _password);
            if (ok)
            {
                await LocalStorage.SetItemAsStringAsync("zabbix_url",      _url);
                await LocalStorage.SetItemAsStringAsync("zabbix_username", _username);
                Toasts.Success("Connected", $"Successfully connected to {_url}");
                Nav.NavigateTo("/");
            }
            else
            {
                Alerts.Error("Connection failed", "Invalid credentials or server unreachable.");
            }
        }
        catch (Exception ex)
        {
            Alerts.Error("Connection error", ex.Message);
        }
        finally
        {
            _connecting = false;
        }
    }

    private async Task DisconnectAsync()
    {
        await Zabbix.LogoutAsync();
        Toasts.Info("Disconnected");
    }
}
