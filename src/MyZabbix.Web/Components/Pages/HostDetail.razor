@page "/hosts/{HostId}"
@rendermode InteractiveServer

<PageTitle>@_hostName — MyZabbix</PageTitle>

@if (!Zabbix.IsAuthenticated)
{
    <div class="alert alert-warning ui-anim-fade-up">
        Not connected. Go to <a href="/settings">Settings</a>.
    </div>
}
else if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted mt-4 ui-anim-fade-up">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span>Loading…</span>
    </div>
}
else
{
    <div class="ui-page-header ui-anim-fade-up">
        <div class="d-flex align-items-center gap-3">
            <a href="/hosts" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h3 class="m-0">
                <i class="bi bi-hdd-network me-2 text-@_statusBadge"></i>@_hostName
            </h3>
            <span class="badge bg-@_statusBadge">@_statusLabel</span>
        </div>
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>

    <!-- Active Triggers -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-lightning-charge text-danger"></i>
                Active Triggers
            </span>
            <span class="badge @(_triggers.Count == 0 ? "bg-success" : "bg-danger")">@_triggers.Count</span>
        </div>
        @if (!_triggers.Any())
        {
            <div class="p-3">
                <div class="d-flex align-items-center gap-2 text-success">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>No active triggers — host looks healthy.</span>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Priority</th>
                            <th>Trigger</th>
                            <th>Last Change</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _triggers)
                        {
                            <tr>
                                <td><span class="badge bg-danger">P@(t.Priority)</span></td>
                                <td class="small">@t.Description</td>
                                <td class="text-muted small">@t.LastChangedAt.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Monitored Items -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-graph-up text-accent"></i>
                Monitored Items
            </span>
            <span class="badge bg-secondary">@_items.Count</span>
        </div>
        @if (!_items.Any())
        {
            <div class="p-3 text-muted small">No items found for this host.</div>
        }
        else
        {
            <div class="px-3 pt-3">
                <UiSearchBar @bind-Value="_itemFilter"
                             Placeholder="Filter items…"
                             Count="@FilteredItems.Count()"
                             CountLabel="items" />
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Key</th>
                            <th>Last Value</th>
                            <th>Updated</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredItems)
                        {
                            <tr>
                                <td class="small fw-semibold">@item.Name</td>
                                <td><code class="small text-muted">@item.Key</code></td>
                                <td class="small">@item.DisplayValue</td>
                                <td class="text-muted small">@item.LastUpdatedAt.ToString("dd.MM HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string HostId { get; set; } = "";

    private bool _loading = true;
    private string _hostName = "";
    private string _statusBadge = "secondary";
    private string _statusLabel = "";
    private List<ZabbixTrigger> _triggers = [];
    private List<ZabbixItem> _items = [];
    private string _itemFilter = "";

    private IEnumerable<ZabbixItem> FilteredItems => string.IsNullOrWhiteSpace(_itemFilter)
        ? _items
        : _items.Where(i => i.Name.Contains(_itemFilter, StringComparison.OrdinalIgnoreCase)
                          || i.Key.Contains(_itemFilter, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated) await LoadAsync();
        else _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var hosts = await Zabbix.GetHostsAsync();
            var host = hosts.FirstOrDefault(h => h.HostId == HostId);
            if (host is not null)
            {
                _hostName    = host.Name;
                _statusBadge = host.StatusBadge;
                _statusLabel = host.StatusLabel;
            }
            else
            {
                _hostName = HostId;
            }

            var triggersTask = Zabbix.GetTriggersAsync(HostId);
            var itemsTask    = Zabbix.GetItemsAsync(HostId);
            await Task.WhenAll(triggersTask, itemsTask);

            _triggers = triggersTask.Result;
            _items    = itemsTask.Result;
        }
        catch (Exception ex)
        {
            Alerts.Error("Failed to load host detail", ex.Message);
            Toasts.ShowError("Chyba", $"Nepodařilo se načíst detail hostu: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
