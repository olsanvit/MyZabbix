@page "/problems"
@implements IDisposable
@inject IJSRuntime JS

<PageTitle>Problems — MyZabbix</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-exclamation-triangle"></i> Active Problems</h3>
    <div class="d-flex gap-2">
        <span class="text-muted small align-self-center">auto-refresh 60s</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
        <button class="btn btn-sm btn-outline-success" @onclick="ExportCsvAsync">
            <i class="bi bi-download me-1"></i>Export CSV
        </button>
    </div>
</div>

@if (!Zabbix.IsAuthenticated)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="d-flex align-items-center gap-3 py-2">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
            <div>
                <div class="fw-semibold">Not connected to Zabbix</div>
                <div class="text-muted small">Go to <a href="/settings">Settings</a> and enter your Zabbix credentials.</div>
            </div>
        </div>
    </div>
}
else if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Loading problems…</span>
    </div>
}
else
{
    <UiSearchBar @bind-Value="_filter" Placeholder="Filter problems, hosts…"
                 Count="_filtered.Count" CountLabel="problems"
                 OnSearch="() => { }">
        <select class="form-select form-select-sm"
                style="max-width:150px;background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:var(--ui-text-1)"
                @bind="_minSeverity">
            <option value="-1">All severities</option>
            <option value="5">Disaster</option>
            <option value="4">High+</option>
            <option value="3">Average+</option>
            <option value="2">Warning+</option>
        </select>
    </UiSearchBar>

    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-exclamation-triangle text-accent"></i>
                Active Problems
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Severity</th>
                        <th>Host</th>
                        <th>Problem</th>
                        <th>Since</th>
                        <th>Age</th>
                        <th class="text-center">Ack</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_filtered.Any())
                    {
                        <tr><td colspan="6" class="text-muted text-center py-4">No active problems 🎉</td></tr>
                    }
                    @foreach (var p in _filtered)
                    {
                        <tr>
                            <td><span class="badge bg-@p.SeverityBadge">@p.SeverityLabel</span></td>
                            <td><small class="text-muted">@p.HostName</small></td>
                            <td><small>@p.Name</small></td>
                            <td><small class="text-muted text-nowrap">@p.OccurredAt.ToString("dd.MM HH:mm")</small></td>
                            <td><small class="text-muted text-nowrap">@(DateTime.Now - p.OccurredAt).Humanize()</small></td>
                            <td class="text-center">
                                @if (p.IsAcknowledged)
                                { <i class="bi bi-check-circle text-success"></i> }
                                else
                                { <i class="bi bi-circle text-muted"></i> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _loading;
    private List<ZabbixProblem> _all = [];
    private string _filter = "";
    private int _minSeverity = -1;
    private System.Threading.Timer? _refreshTimer;

    private List<ZabbixProblem> _filtered => _all
        .Where(p => _minSeverity < 0 || int.TryParse(p.Severity, out var s) && s >= _minSeverity)
        .Where(p => string.IsNullOrWhiteSpace(_filter)
                 || p.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                 || p.HostName.Contains(_filter, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated) await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (Zabbix.IsAuthenticated)
                {
                    await LoadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
        return Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _all = await Zabbix.GetProblemsAsync(); }
        catch (Exception ex) { Alerts.Error("Failed to load problems", ex.Message); }
        finally { _loading = false; }
    }

    private async Task ExportCsvAsync()
    {
        var data = _filtered;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Severity,Host,Problem,Since,Acknowledged");
        foreach (var p in data)
            sb.AppendLine($"\"{p.SeverityLabel}\",\"{p.HostName?.Replace("\"", "\"\"")}\",\"{p.Name?.Replace("\"", "\"\"")}\",{p.OccurredAt:yyyy-MM-dd HH:mm},{p.IsAcknowledged}");
        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        await JS.InvokeVoidAsync("downloadBase64File", "problems.csv", "text/csv", Convert.ToBase64String(bytes));
    }

    public void Dispose() => _refreshTimer?.Dispose();
}
