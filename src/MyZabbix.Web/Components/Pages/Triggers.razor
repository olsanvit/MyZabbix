@page "/triggers"

<PageTitle>Triggers — MyZabbix</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-lightning-charge"></i> Active Triggers</h3>
    <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
</div>

@if (!Zabbix.IsAuthenticated)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="d-flex align-items-center gap-3 py-2">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
            <div>
                <div class="fw-semibold">Not connected to Zabbix</div>
                <div class="text-muted small">Go to <a href="/settings">Settings</a> and enter your Zabbix credentials.</div>
            </div>
        </div>
    </div>
}
else if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Loading triggers…</span>
    </div>
}
else
{
    <UiSearchBar @bind-Value="_filter" Placeholder="Filter triggers, hosts…"
                 Count="_totalItems" CountLabel="triggers in PROBLEM state"
                 OnSearch="ResetPage" />

    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-lightning-charge text-accent"></i>
                Triggers in PROBLEM State
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Priority</th>
                        <th>Host</th>
                        <th>Trigger</th>
                        <th>Last Change</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_pagedTriggers.Any())
                    {
                        <tr><td colspan="4" class="text-muted text-center py-4">No active triggers.</td></tr>
                    }
                    @foreach (var t in _pagedTriggers)
                    {
                        <tr>
                            <td><span class="badge bg-danger">P@(t.Priority)</span></td>
                            <td><small class="text-muted">@t.HostName</small></td>
                            <td><small>@t.Description</small></td>
                            <td><small class="text-muted text-nowrap">@t.LastChangedAt.ToString("dd.MM HH:mm")</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 border-top border-opacity-10">
            <Paginator TotalItems="_totalItems" PageSize="PageSize" CurrentPage="_page"
                       OnPageChanged="p => { _page = p; StateHasChanged(); }" />
        </div>
    </div>
}

@code {
    private bool _loading;
    private List<ZabbixTrigger> _triggers = [];
    private string _filter = "";
    private int _page = 1;
    private const int PageSize = 20;

    private List<ZabbixTrigger> _filtered => string.IsNullOrWhiteSpace(_filter)
        ? _triggers
        : _triggers.Where(t => t.Description.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                             || t.HostName.Contains(_filter, StringComparison.OrdinalIgnoreCase)).ToList();

    private int _totalItems => _filtered.Count;

    private IEnumerable<ZabbixTrigger> _pagedTriggers => _filtered
        .Skip((_page - 1) * PageSize)
        .Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _triggers = await Zabbix.GetTriggersAsync(); }
        catch (Exception ex) { Alerts.Error("Failed to load triggers", ex.Message); }
        finally { _loading = false; }
    }

    private void ResetPage() => _page = 1;
}
