@page "/"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Dashboard — MyZabbix</PageTitle>

<h4 class="mb-4"><i class="bi bi-speedometer2 me-2 text-danger"></i>Dashboard</h4>

@if (!Zabbix.IsAuthenticated)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i>
        Not connected to Zabbix. Go to <a href="/settings">Settings</a> and connect first.
    </div>
}
else if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm"></div> Loading...
    </div>
}
else
{
    <!-- Summary stat badges -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4">
            <div class="card border-0 bg-primary text-white h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                    <div class="fs-1 fw-bold">@_hosts.Count</div>
                    <div class="small"><i class="bi bi-hdd-network me-1"></i>Total Hosts</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card border-0 bg-success text-white h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                    <div class="fs-1 fw-bold">@_hosts.Count(h => h.IsEnabled)</div>
                    <div class="small"><i class="bi bi-check-circle me-1"></i>Enabled Hosts</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="card border-0 bg-danger text-white h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center">
                    <div class="fs-1 fw-bold">@_problems.Count</div>
                    <div class="small"><i class="bi bi-exclamation-triangle me-1"></i>Total Problems</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Problems by severity cards -->
    <h6 class="text-muted mb-2"><i class="bi bi-bar-chart me-1"></i>Problems by Severity</h6>
    <div class="row g-2 mb-4">
        @foreach (var sev in _severityGroups)
        {
            <div class="col-6 col-sm-4 col-md-2">
                <div class="card border-0 text-white h-100" style="background-color:@sev.Color">
                    <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-2">
                        <div class="fs-3 fw-bold">@sev.Count</div>
                        <div class="small fw-semibold">@sev.Label</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="row g-3">
        <!-- Last 5 problems -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-exclamation-triangle me-2 text-danger"></i>Recent Problems</span>
                    <a href="/problems" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                <div class="card-body p-0">
                    @if (_problems.Count == 0)
                    {
                        <p class="text-muted text-center py-3 mb-0">No active problems</p>
                    }
                    else
                    {
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Severity</th>
                                    <th>Problem</th>
                                    <th>Age</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in _problems.Take(5))
                                {
                                    <tr>
                                        <td><span class="badge bg-@p.SeverityBadge">@p.SeverityLabel</span></td>
                                        <td>
                                            <small class="d-block fw-semibold">@p.Name</small>
                                            <small class="text-muted">@p.HostName</small>
                                        </td>
                                        <td><small class="text-muted text-nowrap">@(DateTime.Now - p.OccurredAt).Humanize()</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

        <!-- Last 5 hosts with problems -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-hdd-network me-2 text-danger"></i>Hosts with Problems</span>
                    <a href="/hosts" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                <div class="card-body p-0">
                    @if (_hostsWithProblems.Count == 0)
                    {
                        <p class="text-muted text-center py-3 mb-0">No hosts with problems</p>
                    }
                    else
                    {
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Host</th>
                                    <th>Problems</th>
                                    <th>Worst</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in _hostsWithProblems.Take(5))
                                {
                                    <tr>
                                        <td><small><code>@h.HostName</code></small></td>
                                        <td><span class="badge bg-secondary">@h.Count</span></td>
                                        <td><span class="badge bg-@h.WorstSeverityBadge">@h.WorstSeverityLabel</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading;
    private List<ZabbixHost> _hosts = [];
    private List<ZabbixProblem> _problems = [];
    private System.Threading.Timer? _refreshTimer;

    private record SeverityGroup(string Label, int Count, string Color);
    private record HostProblemSummary(string HostName, int Count, string WorstSeverityLabel, string WorstSeverityBadge);

    private List<SeverityGroup> _severityGroups = [];
    private List<HostProblemSummary> _hostsWithProblems = [];

    private static readonly (int Sev, string Label, string Color)[] SeverityMeta =
    [
        (5, "Disaster",       "#dc3545"),
        (4, "High",           "#fd7e14"),
        (3, "Average",        "#ffc107"),
        (2, "Warning",        "#0dcaf0"),
        (1, "Information",    "#0d6efd"),
        (0, "Not Classified", "#6c757d"),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated)
            await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (Zabbix.IsAuthenticated)
                {
                    await LoadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
        return Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var hostsTask    = Zabbix.GetHostsAsync();
            var problemsTask = Zabbix.GetProblemsAsync();
            await Task.WhenAll(hostsTask, problemsTask);

            _hosts    = hostsTask.Result;
            _problems = problemsTask.Result;

            // Build severity groups
            _severityGroups = SeverityMeta
                .Select(m => new SeverityGroup(
                    m.Label,
                    _problems.Count(p => int.TryParse(p.Severity, out var s) && s == m.Sev),
                    m.Color))
                .ToList();

            // Build hosts-with-problems summary, sorted by problem count desc
            _hostsWithProblems = _problems
                .GroupBy(p => p.HostName)
                .Where(g => !string.IsNullOrEmpty(g.Key))
                .Select(g =>
                {
                    var worstSev = g.Max(p => int.TryParse(p.Severity, out var s) ? s : 0);
                    var worst = g.First(p => int.TryParse(p.Severity, out var s) && s == worstSev);
                    return new HostProblemSummary(g.Key, g.Count(), worst.SeverityLabel, worst.SeverityBadge);
                })
                .OrderByDescending(h => h.Count)
                .ToList();
        }
        catch (Exception ex)
        {
            Alerts.Error("Failed to load dashboard", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose() => _refreshTimer?.Dispose();
}
