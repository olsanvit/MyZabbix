@page "/"
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Dashboard — MyZabbix</PageTitle>

<!-- Page header -->
<div class="ui-page-header ui-anim-fade-up">
    <h3>
        <i class="bi bi-speedometer2"></i>
        Dashboard
    </h3>
    <span class="badge bg-secondary text-muted small">MyZabbix</span>
</div>

@if (!Zabbix.IsAuthenticated)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="d-flex align-items-center gap-3 py-2">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
            <div>
                <div class="fw-semibold">Not connected to Zabbix</div>
                <div class="text-muted small">Go to <a href="/settings">Settings</a> and enter your Zabbix credentials to connect.</div>
            </div>
        </div>
    </div>
}
else if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-4">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Loading Zabbix data…</span>
    </div>
}
else
{
    <!-- Stats row -->
    <div class="row g-3 mb-4 ui-anim-fade-up">
        <div class="col-6 col-lg-3">
            <UiStats Label="Total Hosts"
                     Value="@_hosts.Count.ToString("N0")"
                     Icon="bi-hdd-network"
                     IconBgClass="icon-accent" />
        </div>
        <div class="col-6 col-lg-3">
            <UiStats Label="Enabled Hosts"
                     Value="@_hosts.Count(h => h.IsEnabled).ToString("N0")"
                     Icon="bi-check-circle"
                     IconBgClass="icon-emerald" />
        </div>
        <div class="col-6 col-lg-3">
            <UiStats Label="Active Problems"
                     Value="@_problems.Count.ToString("N0")"
                     Icon="bi-exclamation-triangle"
                     IconBgClass="icon-rose" />
        </div>
        <div class="col-6 col-lg-3">
            <UiStats Label="Disaster / High"
                     Value="@(_problems.Count(p => int.TryParse(p.Severity, out var sv) && sv >= 4).ToString("N0"))"
                     Icon="bi-lightning-charge"
                     IconBgClass="icon-amber" />
        </div>
    </div>

    <!-- Severity chart + quicklinks -->
    <div class="row g-3 mb-4">
        @if (_severityGroups.Any(s => s.Count > 0))
        {
            <div class="col-lg-8">
                <div class="ui-panel ui-anim-fade-up">
                    <div class="ui-panel-header">
                        <span class="ui-panel-title">
                            <i class="bi bi-bar-chart-fill text-accent"></i>
                            Problems by Severity
                        </span>
                    </div>
                    <ApexChart TItem="SeverityGroup" Options="_chartOptions">
                        <ApexPointSeries TItem="SeverityGroup" Name="Count"
                            Items="_severityGroups"
                            XValue="@(e => e.Label)"
                            YValue="@(e => (decimal?)e.Count)"
                            SeriesType="SeriesType.Bar" />
                    </ApexChart>
                </div>
            </div>
        }

        <div class="col-lg-4">
            <div class="d-flex flex-column gap-3 ui-anim-fade-up">
                <QuickLinkCard Href="/hosts"
                               Icon="bi-hdd-network"
                               Title="Hosts"
                               Description="All monitored hosts"
                               IconClass="icon-accent" />
                <QuickLinkCard Href="/problems"
                               Icon="bi-exclamation-triangle-fill"
                               Title="Problems"
                               Description="Active alerts and issues"
                               IconClass="icon-rose" />
                <QuickLinkCard Href="/triggers"
                               Icon="bi-lightning-charge"
                               Title="Triggers"
                               Description="Active trigger rules"
                               IconClass="icon-amber" />
            </div>
        </div>
    </div>

    <!-- Recent problems + hosts with problems -->
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="ui-panel ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-exclamation-triangle text-accent"></i>
                        Recent Problems
                    </span>
                    <a href="/problems" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                @if (_problems.Count == 0)
                {
                    <p class="text-muted text-center py-3 mb-0">No active problems 🎉</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr><th>Severity</th><th>Problem</th><th>Age</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var p in _problems.Take(5))
                                {
                                    <tr>
                                        <td><span class="badge bg-@p.SeverityBadge">@p.SeverityLabel</span></td>
                                        <td>
                                            <small class="d-block fw-semibold">@p.Name</small>
                                            <small class="text-muted">@p.HostName</small>
                                        </td>
                                        <td><small class="text-muted text-nowrap">@(DateTime.Now - p.OccurredAt).Humanize()</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ui-panel ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <i class="bi bi-hdd-network text-accent"></i>
                        Hosts with Problems
                    </span>
                    <a href="/hosts" class="btn btn-sm btn-outline-secondary">View all</a>
                </div>
                @if (_hostsWithProblems.Count == 0)
                {
                    <p class="text-muted text-center py-3 mb-0">No hosts with problems 🎉</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead>
                                <tr><th>Host</th><th>Problems</th><th>Worst</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var h in _hostsWithProblems.Take(5))
                                {
                                    <tr>
                                        <td><small><code>@h.HostName</code></small></td>
                                        <td><span class="badge bg-secondary">@h.Count</span></td>
                                        <td><span class="badge bg-@h.WorstSeverityBadge">@h.WorstSeverityLabel</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loading;
    private List<ZabbixHost> _hosts = [];
    private List<ZabbixProblem> _problems = [];
    private System.Threading.Timer? _refreshTimer;

    private record SeverityGroup(string Label, int Count, string Color);
    private record HostProblemSummary(string HostName, int Count, string WorstSeverityLabel, string WorstSeverityBadge);

    private List<SeverityGroup> _severityGroups = [];
    private List<HostProblemSummary> _hostsWithProblems = [];

    private readonly ApexChartOptions<SeverityGroup> _chartOptions = new()
    {
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false } },
        Chart  = new Chart  { Toolbar = new Toolbar { Show = false }, Background = "transparent" },
        Theme  = new ApexCharts.Theme { Mode = Mode.Dark },
        Colors = ["#f43f5e", "#f97316", "#fbbf24", "#38bdf8", "#6366f1", "#6b7280"],
        Grid   = new Grid  { BorderColor = "rgba(255,255,255,0.08)" }
    };

    private static readonly (int Sev, string Label, string Color)[] SeverityMeta =
    [
        (5, "Disaster",       "#dc3545"),
        (4, "High",           "#fd7e14"),
        (3, "Average",        "#ffc107"),
        (2, "Warning",        "#0dcaf0"),
        (1, "Information",    "#0d6efd"),
        (0, "Not Classified", "#6c757d"),
    ];

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated)
            await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (Zabbix.IsAuthenticated)
                {
                    await LoadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
        return Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var hostsTask    = Zabbix.GetHostsAsync();
            var problemsTask = Zabbix.GetProblemsAsync();
            await Task.WhenAll(hostsTask, problemsTask);

            _hosts    = hostsTask.Result;
            _problems = problemsTask.Result;

            _severityGroups = SeverityMeta
                .Select(m => new SeverityGroup(
                    m.Label,
                    _problems.Count(p => int.TryParse(p.Severity, out var s) && s == m.Sev),
                    m.Color))
                .ToList();

            _hostsWithProblems = _problems
                .GroupBy(p => p.HostName)
                .Where(g => !string.IsNullOrEmpty(g.Key))
                .Select(g =>
                {
                    var worstSev = g.Max(p => int.TryParse(p.Severity, out var s) ? s : 0);
                    var worst = g.First(p => int.TryParse(p.Severity, out var s) && s == worstSev);
                    return new HostProblemSummary(g.Key, g.Count(), worst.SeverityLabel, worst.SeverityBadge);
                })
                .OrderByDescending(h => h.Count)
                .ToList();
        }
        catch (Exception ex)
        {
            Alerts.Error("Failed to load dashboard", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose() => _refreshTimer?.Dispose();
}
