@page "/hosts"

<PageTitle>Hosts — MyZabbix</PageTitle>

<h4 class="mb-4"><i class="bi bi-hdd-network me-2 text-danger"></i>Hosts</h4>

@if (!Zabbix.IsAuthenticated)
{
    <div class="alert alert-warning">Not connected. Go to <a href="/settings">Settings</a>.</div>
}
else if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted"><div class="spinner-border spinner-border-sm"></div> Loading...</div>
}
else
{
    <div class="d-flex gap-2 mb-3 align-items-center">
        <input class="form-control form-control-sm w-auto" placeholder="Filter hosts..." @bind="_filter" @bind:event="oninput" />
        <span class="text-muted small">@_filtered.Count hosts</span>
        <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="LoadAsync">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-sm">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Host</th>
                    <th>Display Name</th>
                    <th>Enabled</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in _filtered)
                {
                    <tr>
                        <td>
                            <span class="badge bg-@h.StatusBadge">
                                <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>@h.StatusLabel
                            </span>
                        </td>
                        <td><code>@h.Host</code></td>
                        <td>@h.Name</td>
                        <td>
                            @if (h.IsEnabled)
                            { <i class="bi bi-check-circle text-success"></i> }
                            else
                            { <i class="bi bi-x-circle text-danger"></i> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _loading;
    private List<ZabbixHost> _hosts = [];
    private string _filter = "";

    private List<ZabbixHost> _filtered => string.IsNullOrWhiteSpace(_filter)
        ? _hosts
        : _hosts.Where(h => h.Host.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                          || h.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _hosts = await Zabbix.GetHostsAsync(); }
        catch (Exception ex) { Alerts.Error("Failed to load hosts", ex.Message); }
        finally { _loading = false; }
    }
}
