@page "/hosts"
@implements IDisposable

<PageTitle>Hosts — MyZabbix</PageTitle>

<h4 class="mb-4"><i class="bi bi-hdd-network me-2 text-danger"></i>Hosts</h4>

@if (!Zabbix.IsAuthenticated)
{
    <div class="alert alert-warning">Not connected. Go to <a href="/settings">Settings</a>.</div>
}
else if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted"><div class="spinner-border spinner-border-sm"></div> Loading...</div>
}
else
{
    <div class="d-flex gap-2 mb-3 align-items-center">
        <input class="form-control form-control-sm w-auto" placeholder="Filter hosts..." @bind="_filter" @bind:event="oninput" />
        <span class="text-muted small">@_totalItems hosts</span>
        <button class="btn btn-sm btn-outline-secondary ms-auto" @onclick="LoadAsync">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
        <span class="text-muted small ms-auto">auto-refresh 60s</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-sm">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Host</th>
                    <th>Display Name</th>
                    <th>Enabled</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var h in _pagedHosts)
                {
                    <tr>
                        <td>
                            <span class="badge bg-@h.StatusBadge">
                                <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>@h.StatusLabel
                            </span>
                        </td>
                        <td><code>@h.Host</code></td>
                        <td>@h.Name</td>
                        <td>
                            @if (h.IsEnabled)
                            { <i class="bi bi-check-circle text-success"></i> }
                            else
                            { <i class="bi bi-x-circle text-danger"></i> }
                        </td>
                        <td>
                            <a href="/hosts/@h.HostId" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye"></i> Detail
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Paginator TotalItems="_totalItems" PageSize="PageSize" CurrentPage="_page"
               OnPageChanged="p => { _page = p; StateHasChanged(); }" />
}

@code {
    private bool _loading;
    private List<ZabbixHost> _hosts = [];
    private string _filter = "";
    private System.Threading.Timer? _refreshTimer;
    private int _page = 1;
    private const int PageSize = 20;

    private List<ZabbixHost> _filtered => string.IsNullOrWhiteSpace(_filter)
        ? _hosts
        : _hosts.Where(h => h.Host.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                          || h.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)).ToList();

    private int _totalItems => _filtered.Count;

    private IEnumerable<ZabbixHost> _pagedHosts => _filtered
        .Skip((_page - 1) * PageSize)
        .Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated) await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (Zabbix.IsAuthenticated)
                {
                    await LoadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
        return Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _hosts = await Zabbix.GetHostsAsync(); }
        catch (Exception ex) { Alerts.Error("Failed to load hosts", ex.Message); Toasts.ShowError("Chyba", $"Nepodařilo se načíst hosty: {ex.Message}"); }
        finally { _loading = false; }
    }

    private void OnFilterChanged(ChangeEventArgs e)
    {
        _filter = e.Value?.ToString() ?? "";
        _page = 1;
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
