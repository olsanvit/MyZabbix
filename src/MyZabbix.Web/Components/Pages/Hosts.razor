@page "/hosts"
@implements IDisposable

<PageTitle>Hosts — MyZabbix</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-hdd-network"></i> Hosts</h3>
    <div class="d-flex gap-2 align-items-center">
        <span class="text-muted small">auto-refresh 60s</span>
        <button class="btn btn-sm btn-outline-secondary" @onclick="LoadAsync">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
</div>

@if (!Zabbix.IsAuthenticated)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="d-flex align-items-center gap-3 py-2">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-4"></i>
            <div>
                <div class="fw-semibold">Not connected to Zabbix</div>
                <div class="text-muted small">Go to <a href="/settings">Settings</a> and enter your Zabbix credentials.</div>
            </div>
        </div>
    </div>
}
else if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Loading hosts…</span>
    </div>
}
else
{
    <UiSearchBar @bind-Value="_filter" Placeholder="Filter hosts…"
                 Count="_totalItems" CountLabel="hosts"
                 OnSearch="ResetPage" />

    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-hdd-network text-accent"></i>
                Monitored Hosts
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Status</th>
                        <th>Host</th>
                        <th>Display Name</th>
                        <th class="text-center">Enabled</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_pagedHosts.Any())
                    {
                        <tr><td colspan="5" class="text-muted text-center py-4">No hosts found.</td></tr>
                    }
                    @foreach (var h in _pagedHosts)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-@h.StatusBadge">
                                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem"></i>@h.StatusLabel
                                </span>
                            </td>
                            <td><a href="/hosts/@h.HostId" class="text-decoration-none"><code class="small">@h.Host</code></a></td>
                            <td><a href="/hosts/@h.HostId" class="text-decoration-none">@h.Name</a></td>
                            <td class="text-center">
                                @if (h.IsEnabled)
                                { <i class="bi bi-check-circle text-success"></i> }
                                else
                                { <i class="bi bi-x-circle text-danger"></i> }
                            </td>
                            <td>
                                <a href="/hosts/@h.HostId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> Detail
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="px-3 py-2 border-top border-opacity-10">
            <Paginator TotalItems="_totalItems" PageSize="PageSize" CurrentPage="_page"
                       OnPageChanged="p => { _page = p; StateHasChanged(); }" />
        </div>
    </div>
}

@code {
    private bool _loading;
    private List<ZabbixHost> _hosts = [];
    private string _filter = "";
    private System.Threading.Timer? _refreshTimer;
    private int _page = 1;
    private const int PageSize = 20;

    private List<ZabbixHost> _filtered => string.IsNullOrWhiteSpace(_filter)
        ? _hosts
        : _hosts.Where(h => h.Host.Contains(_filter, StringComparison.OrdinalIgnoreCase)
                          || h.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase)).ToList();

    private int _totalItems => _filtered.Count;

    private IEnumerable<ZabbixHost> _pagedHosts => _filtered
        .Skip((_page - 1) * PageSize)
        .Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        if (Zabbix.IsAuthenticated) await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _refreshTimer = new System.Threading.Timer(async _ =>
            {
                if (Zabbix.IsAuthenticated)
                {
                    await LoadAsync();
                    await InvokeAsync(StateHasChanged);
                }
            }, null, TimeSpan.FromSeconds(60), TimeSpan.FromSeconds(60));
        }
        return Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _hosts = await Zabbix.GetHostsAsync(); }
        catch (Exception ex) { Alerts.Error("Failed to load hosts", ex.Message); }
        finally { _loading = false; }
    }

    private void ResetPage() => _page = 1;

    public void Dispose() => _refreshTimer?.Dispose();
}
